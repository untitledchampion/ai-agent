# Anthropic Claude API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# SQLite path used by the agent (products + scenes + runtime state)
DATABASE_URL=sqlite+aiosqlite:///./data/chatapp_data_prod.db

# ChatApp.online integration (optional, only for ChatApp webhook collector)
CHATAPP_EMAIL=your-email@example.com
CHATAPP_PASSWORD=your-password
CHATAPP_APP_ID=your-app-id

# Voyage AI embeddings (optional, used by some search scripts)
VOYAGE_API_KEY=pa-...
